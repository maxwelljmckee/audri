{
  "name": "@audri/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "import": "./dist/db/index.js",
      "default": "./dist/db/index.js"
    },
    "./db/client": {
      "types": "./dist/db/client.d.ts",
      "import": "./dist/db/client.js",
      "default": "./dist/db/client.js"
    },
    "./db/schema": {
      "types": "./dist/db/schema/index.d.ts",
      "import": "./dist/db/schema/index.js",
      "default": "./dist/db/schema/index.js"
    },
    "./gemini": {
      "types": "./dist/gemini.d.ts",
      "import": "./dist/gemini.js",
      "default": "./dist/gemini.js"
    },
    "./posthog": {
      "types": "./dist/posthog.d.ts",
      "import": "./dist/posthog.js",
      "default": "./dist/posthog.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "drizzle-orm": "^0.36.4",
    "postgres": "^3.4.5",
    "posthog-node": "^5.31.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
